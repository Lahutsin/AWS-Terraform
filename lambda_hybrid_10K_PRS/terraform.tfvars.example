aws_region   = "eu-central-1"
project_name = "lambda-hybrid"
environment  = "dev"

api_name       = "lambda-hybrid-api"
api_stage_name = "v1"

sync_route_path  = "/sync"
async_route_path = "/async"

api_throttling_burst_limit = 2000
api_throttling_rate_limit  = 1000
api_detailed_metrics_enabled = true

sync_lambda_memory_size   = 512
sync_lambda_timeout       = 10
worker_lambda_memory_size = 512
worker_lambda_timeout     = 30

sync_reserved_concurrency    = 20
sync_provisioned_concurrency = 5

worker_reserved_concurrency               = 10
worker_provisioned_concurrency            = 2
worker_batch_size                         = 10
worker_maximum_batching_window_in_seconds = 5

queue_visibility_timeout_seconds = 180
queue_message_retention_seconds  = 345600
dlq_message_retention_seconds    = 1209600
max_receive_count                = 5

log_retention_in_days = 14

enable_xray                 = true
enable_cloudwatch_dashboard = true
lambda_errors_alarm_threshold         = 1
lambda_throttles_alarm_threshold      = 1
api_5xx_alarm_threshold               = 1
dlq_visible_messages_alarm_threshold  = 1
alarm_period_seconds                  = 60
alarm_evaluation_periods              = 1
enable_alarm_notifications            = true
alarm_notification_email_endpoints    = ["alerts@example.com"]

enable_edge_layer        = true
enable_waf               = true
enable_cloudfront_logging = true
enable_waf_logging       = true
route53_zone_name        = "example.com"
edge_domain_name         = "api.example.com"
cloudfront_price_class   = "PriceClass_100"

cicd_enabled                        = true
cicd_connection_arn                = "arn:aws:codestar-connections:eu-central-1:111111111111:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
cicd_repository_id                 = "owner/repository"
cicd_branch_name                   = "main"
# cicd_artifact_bucket_name_override = "my-unique-artifact-bucket"
cicd_stack_name                    = "lambda-hybrid-sam"

cost_center         = "application"
owner               = "platform-team"
data_classification = "internal"

# s3_bucket_name_override       = "my-globally-unique-bucket-name"
# cloudfront_log_bucket_name_override = "my-unique-cloudfront-log-bucket"
# dynamodb_table_name_override  = "my-request-table"
# s3_bucket_force_destroy       = true